# =====================================================================
# Dhvani production environment — paste into Azure Web App → Configuration
#
# DO NOT commit real values. This file is the shape only.
# Rotate keys through Azure Key Vault or `az openai keys regenerate`.
# =====================================================================

# ---------------------------------------------------------------------
# Azure OpenAI — transcription (Sweden Central — low-carbon grid)
# ---------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://z-oai-innovationhub-dev-swc.openai.azure.com/
AZURE_OPENAI_WHISPER_DEPLOYMENT=gpt-4o-transcribe-diarize
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ---------------------------------------------------------------------
# Azure OpenAI — chat / summary / ask / followup (West Europe — gpt-4.1-mini)
# Omit the _CHAT_ vars to reuse the transcription resource above.
# ---------------------------------------------------------------------
AZURE_OPENAI_CHAT_API_KEY=
AZURE_OPENAI_CHAT_ENDPOINT=https://z-oai-innovationhub-dev-euw.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_CHAT_API_VERSION=2024-12-01-preview

# ---------------------------------------------------------------------
# Microsoft Entra ID — SSO
# From Entra Portal → App registrations → Dhvani.
# ---------------------------------------------------------------------
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ---------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------
# openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://dhvani.itu.int

# ---------------------------------------------------------------------
# Admin & limits
# ---------------------------------------------------------------------
ADMIN_EMAILS=rahul.jha@itu.int
RATE_LIMIT_MINUTES_PER_HOUR=60
RATE_LIMIT_MINUTES_PER_DAY=240
RATE_LIMIT_MONTHLY_BUDGET_USD=500
RATE_LIMIT_CHAT_PER_HOUR=30
SERVICE_ENABLED=true

# ---------------------------------------------------------------------
# Data (leave default unless using Azure Files / NFS for multi-instance)
# ---------------------------------------------------------------------
DHVANI_DATA_DIR=./data

# ---------------------------------------------------------------------
# Feature toggles (omit to leave ON; "false" disables)
# ---------------------------------------------------------------------
FEATURE_SUMMARY=true
FEATURE_ASK_AI=true
FEATURE_CALENDAR=true
FEATURE_UPLOAD=true
FEATURE_SHARING=true

# ---------------------------------------------------------------------
# Optional — outbound event webhook (Teams / Slack / Zapier)
# ---------------------------------------------------------------------
# NOTIFICATION_WEBHOOK_URL=

# ---------------------------------------------------------------------
# Optional — Electron distribution target
# ---------------------------------------------------------------------
# DHVANI_SERVER_URL=https://dhvani.itu.int
