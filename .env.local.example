# ============================================================
# Dhvani — environment variables
# All values are read server-side only. Nothing here is exposed
# to the browser bundle.
# ============================================================

# --- Azure OpenAI (managed by org admin) -----------------------------
# Transcription runs against the org's Azure OpenAI resource so audio
# never leaves the Azure tenant. All three values come from
# Azure AI Foundry → Deployments → whisper.
AZURE_OPENAI_API_KEY=
# e.g. https://z-oai-innovationhub-dev-euw.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
# The deployment name you created in Azure AI Foundry (NOT the upstream
# model id). Dhvani defaults to gpt-4o-transcribe-diarize which provides
# speaker diarization out of the box. Set to "whisper-1" to fall back to
# the legacy Whisper model (no speaker labels).
AZURE_OPENAI_WHISPER_DEPLOYMENT=gpt-4o-transcribe-diarize
# Chat model for AI summary / "Ask Dhvani". Must be a chat/completions
# deployment on the same Azure OpenAI resource (gpt-4o, gpt-4o-mini, etc.)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# --- Microsoft Entra ID / Azure AD -----------------------------------
# Create an App Registration in Azure AD, then grab these values:
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# --- NextAuth --------------------------------------------------------
# Generate a strong random secret (e.g. `openssl rand -base64 32`).
NEXTAUTH_SECRET=generate-a-random-secret-here
# Public origin of the deployment. Must match the App Registration's
# redirect URI: <NEXTAUTH_URL>/api/auth/callback/microsoft-entra-id
NEXTAUTH_URL=https://dhvani.itu.int

# --- Admin -----------------------------------------------------------
# Comma-separated list of emails allowed to view /admin and call the
# /api/admin/* routes.
ADMIN_EMAILS=rahul.jha@itu.int

# --- Rate Limits -----------------------------------------------------
# Per-user sliding-window caps. Adjust based on how your org uses Dhvani.
RATE_LIMIT_MINUTES_PER_HOUR=60
RATE_LIMIT_MINUTES_PER_DAY=240
# Org-wide cap. Transcription is refused once monthly spend crosses
# this. Reset happens at UTC start of each month.
RATE_LIMIT_MONTHLY_BUDGET_USD=500

# --- Data ------------------------------------------------------------
# Append-only JSONL log of per-chunk usage. In Docker this lives on a
# mounted volume (default /app/data); locally we write to ./data.
USAGE_LOG_PATH=./data/usage-log.jsonl

# Where saved transcripts are stored. Mount a persistent volume here in
# production (Azure Files, NFS, etc.). Default: ./data/transcripts
# DHVANI_DATA_DIR=./data/transcripts

# --- Kill switch (optional) -----------------------------------------
# Set to "false" to reject all /api/transcribe requests with 503. The
# admin dashboard toggle writes to this at runtime.
# SERVICE_ENABLED=true
