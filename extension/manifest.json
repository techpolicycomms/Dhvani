{
  "manifest_version": 3,
  "name": "Dhvani — ITU Meeting Transcription",
  "description": "Real-time meeting transcription with speaker identification. An ITU Innovation Hub tool.",
  "version": "1.0.0",
  "permissions": [
    "tabCapture",
    "activeTab",
    "sidePanel",
    "storage",
    "notifications",
    "offscreen",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://app-dhvani.azurewebsites.net/*",
    "https://teams.microsoft.com/*",
    "https://*.zoom.us/*",
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Dhvani Transcription",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.zoom.us/*",
        "https://meet.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html"],
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.zoom.us/*",
        "https://meet.google.com/*"
      ]
    }
  ]
}
