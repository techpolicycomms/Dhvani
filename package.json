{
  "name": "dhvani",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist/main.js",
  "description": "Open-source multilingual meeting transcription for everyone.",
  "license": "MIT",
  "homepage": "https://github.com/techpolicycomms/dhvani",
  "repository": {
    "type": "git",
    "url": "https://github.com/techpolicycomms/dhvani.git"
  },
  "scripts": {
    "predev": "node scripts/ensure-project-root.mjs",
    "preelectron:dev": "node scripts/ensure-project-root.mjs",
    "prebuild": "node scripts/ensure-project-root.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron electron/dist/main.js\"",
    "electron:build": "tsc -p electron/tsconfig.json && electron-builder -mw",
    "electron:build:mac": "tsc -p electron/tsconfig.json && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "electron:build:win": "tsc -p electron/tsconfig.json && electron-builder --win nsis",
    "electron:build:demo": "next build && node scripts/copy-electron-standalone-assets.mjs && tsc -p electron/tsconfig.json && DEMO_BUILD=true CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --config.extraMetadata.demoBuild=true --config.files.0=electron/dist/**/* --config.files.1=.next/standalone/**/* --config.files.2=.next/static/**/* --config.files.3=public/**/* --config.files.4=package.json",
    "release": "npm version patch && git push && git push --tags"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "org.techpolicycomms.dhvani",
    "productName": "Dhvani",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/dist/**/*",
      "public/icons/**/*",
      "public/manifest.json",
      "package.json",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
