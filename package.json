{
  "name": "dhvani",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist/main.js",
  "description": "Open-source multilingual meeting transcription for everyone.",
  "license": "MIT",
  "homepage": "https://github.com/techpolicycomms/dhvani",
  "repository": {
    "type": "git",
    "url": "https://github.com/techpolicycomms/dhvani.git"
  },
  "scripts": {
    "predev": "node scripts/ensure-project-root.mjs",
    "preelectron:dev": "node scripts/ensure-project-root.mjs",
    "prebuild": "node scripts/ensure-project-root.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron electron/dist/main.js\"",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/write-electron-build-config.mjs",
    "package:mac": "electron-builder --mac",
    "package:mac:localhost": "DHVANI_BUILD_SERVER_URL=http://localhost:3000 npm run build:electron && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:all": "electron-builder -mw",
    "electron:build": "tsc -p electron/tsconfig.json && electron-builder -mw",
    "electron:build:mac": "tsc -p electron/tsconfig.json && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "electron:build:win": "tsc -p electron/tsconfig.json && electron-builder --win nsis",
    "qa:sweep": "node scripts/e2e/sweep.mjs",
    "qa:smoke": "node scripts/e2e/record-smoke.mjs",
    "qa:all": "npm run qa:sweep && npm run qa:smoke",
    "release": "npm version patch && git push && git push --tags",
    "mobile:doctor": "npx cap doctor",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:run:android": "npx cap run android"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@xenova/transformers": "^2.17.2",
    "docx": "^9.6.1",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.itu.dhvani",
    "productName": "Dhvani",
    "asar": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/dist/**/*",
      "public/icons/**/*",
      "public/manifest.json",
      "package.json",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dhvani needs your microphone to capture your side of the meeting.",
        "NSCameraUsageDescription": "Dhvani uses ScreenCaptureKit to capture system audio; no video is recorded or saved."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
