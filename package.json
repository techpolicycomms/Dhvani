{
  "name": "dhvani",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source multilingual meeting transcription for everyone.",
  "main": "electron/main.js",
  "license": "MIT",
  "homepage": "https://github.com/techpolicycomms/dhvani",
  "repository": {
    "type": "git",
    "url": "https://github.com/techpolicycomms/dhvani.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
    "electron:prepare": "node scripts/copy-electron-standalone-assets.mjs && tsc -p electron/tsconfig.json",
    "electron:build": "next build && npm run electron:prepare && electron-builder -mw",
    "electron:build:mac": "next build && npm run electron:prepare && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "electron:build:win": "next build && npm run electron:prepare && electron-builder --win nsis"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.20",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "org.techpolicycomms.dhvani",
    "productName": "Dhvani",
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "afterPack": "scripts/afterPack.mjs",
    "files": [
      "electron/**/*.js",
      "electron/**/*.html",
      {
        "from": ".next/standalone",
        "to": ".next/standalone",
        "filter": ["**/*"]
      },
      ".next/static/**/*",
      "public/**/*",
      "package.json",
      "!**/node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/.bin",
      "!src",
      "!electron/src"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg" }
      ],
      "darkModeSupport": false,
      "hardenedRuntime": false,
      "identity": null
    },
    "dmg": {
      "title": "Dhvani",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": "nsis"
    }
  }
}
