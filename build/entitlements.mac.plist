<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Entitlements for the Hardened Runtime. electron-builder applies this
      to the main app and, via entitlementsInherit, to every helper
      process (Renderer / GPU / Plugin / Utility). All three flags below
      are required for system-audio transcription on macOS 13+:

        - device.audio-input  : Microphone capture (getUserMedia).
        - device.camera       : Required by ScreenCaptureKit for
                                 getDisplayMedia, even though we strip
                                 video tracks immediately. Not checking
                                 this breaks the audio loopback.
        - files.user-selected : Save/export transcripts to disk.

      com.apple.security.cs.allow-jit and allow-unsigned-executable-memory
      are required by Chromium's V8 engine under Hardened Runtime.
    -->

    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.camera</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow child processes to inherit the parent's entitlements. -->
    <key>com.apple.security.inherit</key>
    <true/>
</dict>
</plist>
